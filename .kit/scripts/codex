#!/bin/sh
# codex: Launch Codex CLI using the VSCode extension's native binary.
# Works on macOS / Linux (incl. VSCode Remote / WSL / devcontainers).
# Dynamically finds the latest installed version so it follows extension updates.

EXT=""
for base in "$HOME/.vscode/extensions" "$HOME/.vscode-server/extensions" "$HOME/.vscode-insiders/extensions"; do
  [ -d "$base" ] || continue
  FOUND=$(ls -d "$base"/openai.chatgpt-* 2>/dev/null | sort -V | tail -1)
  if [ -n "$FOUND" ]; then
    EXT="$FOUND"
    break
  fi
done

if [ -z "$EXT" ]; then
  echo "Error: OpenAI ChatGPT VSCode extension not found." >&2
  echo "Install 'ChatGPT' (openai.chatgpt) from the VSCode marketplace first." >&2
  exit 1
fi

CODEX=$(ls "$EXT"/bin/*/codex 2>/dev/null | head -1)

if [ -z "$CODEX" ] || [ ! -x "$CODEX" ]; then
  echo "Error: Codex binary not found under $EXT/bin/" >&2
  exit 1
fi

exec "$CODEX" "$@"
