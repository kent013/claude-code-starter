#!/bin/sh
# claude: Launch Claude Code CLI using the VSCode extension's native binary.
# Works on macOS / Linux (incl. VSCode Remote / WSL / devcontainers).
# Dynamically finds the latest installed version so it follows extension updates.

EXT=""
for base in "$HOME/.vscode/extensions" "$HOME/.vscode-server/extensions" "$HOME/.vscode-insiders/extensions"; do
  [ -d "$base" ] || continue
  FOUND=$(ls -d "$base"/anthropic.claude-code-* 2>/dev/null | sort -V | tail -1)
  if [ -n "$FOUND" ]; then
    EXT="$FOUND"
    break
  fi
done

if [ -z "$EXT" ]; then
  echo "Error: anthropic.claude-code VSCode extension not found." >&2
  echo "Install 'Claude Code' from the VSCode marketplace first." >&2
  exit 1
fi

CLAUDE="$EXT/resources/native-binary/claude"

if [ ! -x "$CLAUDE" ]; then
  echo "Error: Claude Code binary not found at $CLAUDE" >&2
  exit 1
fi

exec "$CLAUDE" "$@"
