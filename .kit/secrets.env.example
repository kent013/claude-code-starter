# claude-code-starter MCP 認証情報
# このファイルは setup スキル実行時に workspace/secrets.env にコピーされます。
# workspace/ は gitignore 対象なので、トークンが誤ってコミットされる心配はありません。
#
# 値を入れたら、setup スキルを再実行すると VSCode 設定（claudeCode.environmentVariables）
# への反映方法を案内します。

# GitHub Personal Access Token
# https://github.com/settings/tokens から発行（repo, read:org スコープ推奨）
GITHUB_PERSONAL_ACCESS_TOKEN=

# Backlog
# https://<your-space>.backlog.com/EditApiSettings.action から発行
BACKLOG_DOMAIN=
BACKLOG_API_KEY=

# Google Drive
# OAuth クレデンシャル JSON のパス（後述の Google Cloud Console で取得）
GDRIVE_CREDENTIALS_PATH=

# Context7 / DocBase は不要（Context7 はパブリック、DocBase は OAuth で自動認証）
